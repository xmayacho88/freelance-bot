import os
import requests

print("1. Файл запущен")

TOKEN = os.environ.get("TELEGRAM_TOKEN")
CHAT_ID = os.environ.get("CHAT_ID")

print(f"2. Токен: {'есть' if TOKEN else 'нет'}")
print(f"3. Chat ID: {'есть' if CHAT_ID else 'нет'}")

if TOKEN and CHAT_ID:
    try:
        url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
        result = requests.post(url, json={"chat_id": CHAT_ID, "text": "✅ Тест от GitHub Actions"})
        print(f"4. Статус ответа: {result.status_code}")
    except Exception as e:
        print(f"4. Ошибка: {e}")
else:
    print("4. Не могу отправить - нет токенов")

print("5. Скрипт закончил работу")